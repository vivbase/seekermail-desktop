# ---- Bundled ONNX model weights (large, binary) — fetched by scripts/setup-model.mjs (T010) ----
# Ignore everything fetched into resources/, but KEEP the dir marker and the pinned lock.
/src-tauri/resources/*
!/src-tauri/resources/.gitkeep
!/src-tauri/resources/model.lock.json

