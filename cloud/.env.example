# SeekerMail Cloud — environment variables
# Copy this file to .env for local development.
# On Railway: set these in the project's Variables tab — never commit a real .env.

# ── Required ──────────────────────────────────────────────────────────────────

# Postgres connection URL.
# On Railway this is auto-populated when you add a Postgres service.
# Locally: postgresql://postgres:password@localhost:5432/seekermail_cloud
DATABASE_URL=

# Your Google OAuth Client ID (Desktop app type).
# Get this from Google Cloud Console — see docs/dev/15_GOOGLE_OAUTH_DESKTOP_CLIENT_SETUP_RUNBOOK.md
# Format: xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OIDC_AUDIENCE=

# A random secret used for session token integrity.
# Generate with: openssl rand -hex 32
SESSION_TOKEN_SECRET=

# ── Optional (have sensible defaults) ────────────────────────────────────────

# How long session tokens are valid, in seconds. Default: 2592000 (30 days).
# SESSION_TTL_SECS=2592000

# TCP port to bind on. Railway sets this automatically.
# PORT=8080
