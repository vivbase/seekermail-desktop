<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements (T056, dev/05 §1.2) — the MINIMAL set.

  Granted:
    * network.client — outbound IMAP/SMTP to the user's mail servers, the
      update check, and (v0.5+) the user-configured BYO-AI endpoint.

  Deliberately ABSENT (deny by default):
    * com.apple.security.network.server          — no listening sockets
    * com.apple.security.device.audio-input      — no microphone
    * com.apple.security.device.camera           — no camera
    * com.apple.security.cs.allow-jit            — no JIT
    * com.apple.security.cs.disable-library-validation — library validation ON
  Adding any entitlement here requires a privacy-gate review (planning/05 §2.3).
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
