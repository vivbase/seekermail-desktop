# SeekerMail — local config. NON-SECRET toggles only.
#
# Copy to `.env` (git-ignored) and adjust. `.env` is NEVER committed.
# Runtime credentials — IMAP/SMTP passwords, OAuth tokens, AI API keys — live in
# the OS Keychain via the `keychain` module (T006), never in this file, the DB,
# the frontend, or logs (08 §7).

# Backend log verbosity (Rust `tracing` EnvFilter). Examples: info | debug | trace
# Default when unset: info,seekermail_lib=debug
SEEKERMAIL_LOG=info

# Optional: override the app data directory (DB, logs, vectors, attachments).
# Defaults to the OS app-support dir (~/Library/Application Support/SeekerMail).
# SEEKERMAIL_DATA_DIR=

# Optional: pin the embedding-model commit revision for `pnpm run setup:model`.
# Leave unset to resolve-and-pin on first fetch (trust-on-first-use, T010).
# SEEKERMAIL_MODEL_REVISION=
